# Copy this file to .env and fill with your own values.

# Required in production. For local dev, app will auto-create fallback secrets in local_web_portal/data/.
APP_SESSION_SECRET=
APP_ENCRYPTION_KEY=

# 0 for local dev, 1 behind HTTPS reverse proxy.
APP_HTTPS_ONLY=0

# Optional: defaults to sqlite in local_web_portal/data/app.db
APP_DATABASE_URL=

# Runtime tuning for generation jobs started from web UI
WEB_BUILTIN_PROVIDERS=deepseek
WEB_MODELLESS_MODE=0
DISABLE_EMBEDDING_DOWNLOADS=1
WEB_MAX_ITERATIONS=8
WEB_MAX_TOTAL_ITERATIONS=16
WEB_JOB_TIMEOUT_SECONDS=0
WEB_JOB_IDLE_TIMEOUT_SECONDS=0
WEB_STARTUP_RECOVERY_SECONDS=180
WEB_STALE_QUEUED_SECONDS=180
WEB_DEFAULT_PROVIDER=deepseek
WEB_FAST_MODE=1
WEB_FULL_CYCLE_INTERVAL=3
WEB_CHAPTERS_PER_ITER=1
WEB_MAX_CHAPTER_SUBROUNDS=2
WEB_EVAL_INTERVAL=8
EMBEDDING_MODEL=none

# LLM HTTP timeout/retry (used by worker process)
LLM_TIMEOUT_SECONDS=0
LLM_MAX_RETRIES=1

# Provider base/model defaults (optional)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CODEX_BASE_URL=https://codex-api.packycode.com/v1
CODEX_MODEL=gpt-5.2
